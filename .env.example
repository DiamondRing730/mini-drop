# Copy to .env and fill in — .env is gitignored, this template is committed.
# Mini-Drop AI smart attribution backends. All optional: with no key set, the
# deterministic heuristic engine runs, so attribution works fully offline.
# Backend preference at runtime: DeepSeek -> Claude -> heuristic.

# DeepSeek (OpenAI-compatible function calling). https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Anthropic Claude. https://console.anthropic.com/
ANTHROPIC_API_KEY=
